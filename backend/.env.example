# Application
APP_NAME=KitchenMate
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database — SQLite (default)
# Switch to MySQL by setting DB_DRIVER=mysql and filling MYSQL_* vars below.
DB_DRIVER=sqlite
SQLITE_PATH=./data/kitchenmate.db

# MySQL (optional, used when DB_DRIVER=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=kitchenmate
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=kitchenmate

# Or override with a full URL (takes precedence over DB_DRIVER)
# DATABASE_URL=sqlite:///./data/kitchenmate.db
# DATABASE_URL=mysql+pymysql://kitchenmate:changeme@localhost:3306/kitchenmate?charset=utf8mb4

# JWT
SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# WeChat Mini Program
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# wxacode 打开版本：trial=体验版 release=正式版 develop=开发版
WECHAT_ENV_VERSION=trial

# CORS (comma-separated origins)
CORS_ORIGINS=*
