@import "../../styles/top-bar.wxss";
@import "../../styles/page-common.wxss";

.page {
  min-height: 100vh;
  background: #F7F2EC;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 20rpx;
  color: #A08B6F;
  font-size: 26rpx;
}

.loading-ring {
  width: 64rpx;
  height: 64rpx;
  border: 5rpx solid #F0E4D0;
  border-top-color: #D4A574;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-emoji { font-size: 80rpx; line-height: 1; }
.empty-title { margin-top: 24rpx; font-size: 34rpx; font-weight: 700; color: #3D2817; }
.empty-desc { margin-top: 16rpx; font-size: 26rpx; color: #A08B6F; line-height: 1.6; }


/* 汇总卡 */
.summary-card {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 111, 71, 0.08);
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.summary-dot {
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #E8A060, #C87E40);
  border-radius: 4rpx;
}

.summary-title { font-size: 30rpx; font-weight: 700; color: #3D2817; flex: 1; }

.live-tag {
  padding: 4rpx 14rpx;
  font-size: 20rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.live-tag.on {
  background: rgba(76, 175, 80, 0.12);
  color: #4CAF50;
}

.live-tag.off {
  background: rgba(255, 152, 0, 0.12);
  color: #F57C00;
}

.summary-dishes {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.summary-dish {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: #FAF6F0;
  border-radius: 16rpx;
  min-width: calc(50% - 8rpx);
  box-sizing: border-box;
}

.summary-dish-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.summary-dish-info {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.summary-dish-name {
  font-size: 26rpx;
  color: #3D2817;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-dish-qty {
  font-size: 28rpx;
  font-weight: 700;
  color: #C87E40;
  flex-shrink: 0;
}

/* 区块 */
.section { margin: 24rpx 24rpx 0; }

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.section-dot {
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #E8A060, #C87E40);
  border-radius: 4rpx;
}

.section-header text { font-size: 30rpx; font-weight: 700; color: #3D2817; }

/* 按人分组 */
.user-group {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.06);
}

.user-group-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD4A3, #E8A060);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-name { font-size: 28rpx; font-weight: 600; color: #3D2817; }

.user-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #F8F2EB;
}

.user-item:last-child { border-bottom: none; }

.user-item-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.user-item-main { flex: 1; min-width: 0; }
.user-item-top { display: flex; align-items: center; justify-content: space-between; }
.user-item-name { font-size: 26rpx; color: #666; flex: 1; }
.user-item-qty { font-size: 26rpx; font-weight: 600; color: #C87E40; flex-shrink: 0; margin-left: 8rpx; }
.user-item-note { display: block; margin-top: 4rpx; font-size: 22rpx; color: #A08B6F; }

/* 订单卡 */
.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.06);
}

.order-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-user { display: flex; align-items: center; gap: 10rpx; }
.order-user-name { font-size: 28rpx; font-weight: 600; color: #3D2817; }

.me-tag {
  padding: 2rpx 12rpx;
  background: #F5EDE3;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #A08B6F;
}

.order-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-pending { background: rgba(255, 152, 0, 0.12); color: #F57C00; }
.status-accepted { background: rgba(33, 150, 243, 0.12); color: #1976D2; }
.status-cooking { background: rgba(156, 39, 176, 0.12); color: #7B1FA2; }
.status-done { background: rgba(76, 175, 80, 0.12); color: #388E3C; }
.status-cancelled { background: #F5F5F5; color: #999; }

.order-item-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 0;
}

.order-item-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F5EDE3;
}

.order-item-name { flex: 1; font-size: 26rpx; color: #555; }
.order-item-meta { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.order-item-user { font-size: 22rpx; color: #A08B6F; }
.order-item-qty { font-size: 26rpx; font-weight: 600; color: #C87E40; }

.lock-bar,
.submit-bar {
  margin: 32rpx 24rpx 48rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(61, 40, 23, 0.06);
}

.lock-hint,
.submit-hint {
  font-size: 24rpx;
  color: #888;
  text-align: center;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.lock-btn,
.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #E8A060, #C87E40);
}

.lock-btn.disabled,
.submit-btn.disabled { opacity: 0.6; }
.lock-btn:active,
.submit-btn:active { opacity: 0.85; }

.order-note {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #FAF6F0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #888;
}

.order-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F8F2EB;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: #F5EDE3;
  color: #8B6F47;
}

.action-btn.primary {
  background: linear-gradient(135deg, #E8A060, #C87E40);
  color: #fff;
}

.action-btn.danger {
  background: #FFF1F0;
  color: #E64340;
}

.action-btn:active { opacity: 0.85; }
