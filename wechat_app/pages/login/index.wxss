.login-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.login-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, #fff5ed 0%, #fef8f4 45%, #ffffff 100%);
}

.login-content {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 64rpx;
  box-sizing: border-box;
}

.logo {
  width: 360rpx;
  height: auto;
  display: block;
}

.app-name {
  margin-top: 32rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 2rpx;
}

.login-panel {
  width: 100%;
  margin-top: 96rpx;
}

.profile-popup {
  width: 640rpx !important;
  max-width: 90vw;
}

.profile-dialog {
  padding: 48rpx 40rpx 40rpx;
  box-sizing: border-box;
}

.profile-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
}

.profile-subtitle {
  margin-top: 12rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  color: #888;
  text-align: center;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 32rpx 0 16rpx;
}

.avatar-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
}

.avatar-btn-overlay {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  opacity: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
}

.avatar-btn-overlay::after {
  border: none;
}

.avatar-btn {
  width: 140rpx !important;
  height: 140rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 50%;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: block;
}

.avatar-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #e64340;
  text-align: center;
  width: 100%;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.loading-box,
.action-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #666;
}

.login-btn {
  width: 100% !important;
}

.login-hint {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.login-ok-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 20rpx 0 8rpx;
  padding: 12rpx 20rpx;
  background: #f6ffed;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #389e0d;
}

.avatar-wrap.disabled {
  opacity: 0.5;
}

.avatar-tip.muted {
  color: #999;
}
