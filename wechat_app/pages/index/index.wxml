<view class="page">

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading-ring"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 未加入家庭 -->
  <view wx:elif="{{!currentFamilyId}}" class="no-family-page">
    <view class="no-family-deco"></view>
    <view class="no-family-card">
      <text class="no-family-emoji">🏠</text>
      <view class="no-family-title">还没有家庭</view>
      <view class="no-family-desc">加入或创建一个家庭，才能浏览菜单、开始点餐；也可以输入聚会码参加临时聚会</view>
      <view class="btn-primary" bindtap="goFamily">去我的家庭</view>
      <view class="btn-secondary mt32" bindtap="goParty">参加聚会</view>
    </view>
  </view>

  <!-- 主菜单页 -->
  <view wx:else class="menu-page">

    <van-sticky z-index="{{99}}">
      <view class="top-bar" bindtap="showFamilyPicker">
        <view class="top-bar-left">
          <view class="cook-badge {{inPartyMode ? 'party' : ''}}">
            <van-icon
              name="{{inPartyMode ? 'gift-o' : 'fire-o'}}"
              size="36rpx"
              color="{{inPartyMode ? '#e64340' : '#D4A574'}}"
            />
          </view>
          <view class="top-bar-info">
            <view class="top-bar-family">{{inPartyMode ? partyName : currentFamilyName}}</view>
            <view class="top-bar-cook" wx:if="{{inPartyMode}}">
              {{isPartyGuest ? '聚会来宾 · 共享点餐' : currentFamilyName + ' · 聚会模式'}}
            </view>
            <view class="top-bar-cook" wx:elif="{{menuSubtitle}}">{{menuSubtitle}}</view>
          </view>
        </view>
        <view class="top-bar-right" wx:if="{{canSwitchFamily}}">
          <text class="top-bar-switch">切换家庭</text>
          <van-icon name="arrow-down" size="24rpx" color="#C4A57B" />
        </view>
        <view class="top-bar-right party-code" wx:elif="{{inPartyMode}}">
          <text class="top-bar-switch">聚会码 {{joinCode}}</text>
        </view>
      </view>
    </van-sticky>

    <view wx:if="{{inPartyMode}}" class="party-banner" bindtap="goParty">
      <text class="party-banner-emoji">🎉</text>
      <view class="party-banner-text">
        <text class="party-banner-title">聚会进行中</text>
        <text class="party-banner-sub">来宾可同桌加菜 · 点击查看聚会详情</text>
      </view>
      <van-icon name="arrow" size="28rpx" color="#C87E40" />
    </view>

    <view wx:if="{{menuEmpty}}" class="empty-box">
      <text class="empty-emoji">🍽️</text>
      <view class="empty-title">还没有菜品</view>
      <view class="empty-desc">{{inPartyMode ? '聚会参与者可在「我的菜品」上架菜品，创建者与众来宾的菜会合并展示' : '每位成员管理自己的菜单，去「我的菜品」添加并上架吧'}}</view>
      <view class="btn-primary mt32" bindtap="goMyDishes">管理我的菜品</view>
    </view>

    <view wx:else class="grid-outer">
      <view wx:if="{{canFilterMenu}}" class="menu-filter-wrap">
        <view class="menu-filter-head">
          <view class="menu-filter-title">
            <van-icon name="filter-o" size="28rpx" color="#C87E40" />
            <text>{{menuFilterLabel}}</text>
          </view>
          <view class="menu-filter-btn" bindtap="showMenuFilterPicker">
            <text>切换菜单</text>
            <van-icon name="arrow-down" size="22rpx" color="#C87E40" />
          </view>
        </view>
        <scroll-view scroll-x class="menu-filter-scroll" enable-flex show-scrollbar="{{false}}">
          <view
            class="menu-filter-chip {{menuFilterMemberId === item.id ? 'active' : ''}}"
            wx:for="{{menuFilterOptions}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onMenuFilterTap"
          >
            {{item.label}}
          </view>
        </scroll-view>
      </view>

      <view wx:if="{{dishGroups.length === 0 && canFilterMenu}}" class="filter-empty-box">
        <text class="empty-emoji">🍳</text>
        <view class="empty-title">这位还没有上架菜品</view>
        <view class="empty-desc">试试切换查看其他人的菜单</view>
        <view class="btn-secondary mt32" bindtap="showMenuFilterPicker">切换菜单</view>
      </view>

      <block wx:else>
        <block wx:for="{{dishGroups}}" wx:key="memberId" wx:for-item="group">
          <view class="section-label" wx:if="{{!canFilterMenu || !menuFilterMemberId}}">
            <view class="section-dot"></view>
            <text>{{group.memberName}}</text>
            <text class="section-count">{{group.dishes.length}}道</text>
          </view>
          <view class="grid">
            <view
              class="grid-cell"
              wx:for="{{group.dishes}}"
              wx:for-item="item"
              wx:key="id"
              style="animation-delay: {{index * 60}}ms"
            >
              <view class="dish-card">
                <view class="dish-img-wrap">
                  <image
                    class="dish-img"
                    src="{{item.imageUrl || '/images/default.png'}}"
                    mode="aspectFill"
                    lazy-load
                  ></image>
                  <view class="dish-gradient"></view>
                  <view class="dish-name-overlay">
                    <view class="dish-name-text">{{item.name}}</view>
                    <view wx:if="{{item.description}}" class="dish-desc-text">{{item.description}}</view>
                  </view>
                </view>
                <view class="dish-footer">
                  <view class="dish-stepper">
                    <view
                      wx:if="{{item.cartQty > 0}}"
                      class="step-btn minus"
                      data-id="{{item.id}}"
                      catchtap="minusDish"
                    >−</view>
                    <text wx:if="{{item.cartQty > 0}}" class="step-qty">{{item.cartQty}}</text>
                    <view class="step-btn plus" data-dish="{{item}}" catchtap="openAddSheet">+</view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </block>
      </block>
    </view>

    <!-- 底部本桌购物车栏（加菜/购物车弹窗打开时隐藏，避免遮挡） -->
    <view wx:if="{{cartCount > 0 && !cartShow && !addSheetShow}}" class="cart-bar">
      <view class="cart-bar-left" bindtap="openCart">
        <view class="cart-icon-wrap">
          <van-icon name="shopping-cart-o" size="44rpx" color="#fff" />
          <view class="cart-badge">{{cartCount}}</view>
        </view>
        <view class="cart-bar-text">本桌已点 {{cartCount}} 道 · 实时同步</view>
      </view>
      <view class="cart-bar-btn view-only" catchtap="openCart">查看</view>
    </view>

    <view wx:if="{{!cartShow && !addSheetShow}}" class="fab" bindtap="goMyDishes">
      <van-icon name="edit" size="36rpx" color="#fff" />
      <text class="fab-label">管理</text>
    </view>

  </view>

  <!-- 加菜弹层（含备注）-->
  <van-popup
    show="{{addSheetShow}}"
    position="bottom"
    round
    z-index="{{1010}}"
    bind:close="closeAddSheet"
  >
    <view class="add-sheet" wx:if="{{addSheetDish}}">
      <view class="add-sheet-header">
        <image class="add-sheet-img" src="{{addSheetDish.imageUrl || '/images/default.png'}}" mode="aspectFill"></image>
        <view class="add-sheet-info">
          <view class="add-sheet-name">{{addSheetDish.name}}</view>
          <view wx:if="{{addSheetDish.description}}" class="add-sheet-desc">{{addSheetDish.description}}</view>
        </view>
      </view>
      <view class="add-sheet-row">
        <text class="add-sheet-label">数量</text>
        <view class="add-sheet-stepper">
          <view class="sheet-step-btn minus" catchtap="sheetMinus">−</view>
          <text class="sheet-step-qty">{{addSheetQty}}</text>
          <view class="sheet-step-btn plus" catchtap="sheetPlus">+</view>
        </view>
      </view>
      <view class="add-sheet-row note-row">
        <text class="add-sheet-label">备注</text>
        <textarea
          class="add-sheet-note"
          placeholder="口味、忌口、特殊要求（选填）"
          maxlength="50"
          value="{{addSheetNote}}"
          bindinput="onAddSheetNoteInput"
          auto-height
          adjust-position
        />
      </view>
      <view class="add-sheet-footer">
        <view class="sheet-cancel-btn" catchtap="closeAddSheet">取消</view>
        <view class="sheet-confirm-btn" catchtap="confirmAddSheet">{{cartUpdating ? '加入中...' : '加入本桌'}}</view>
      </view>
    </view>
  </van-popup>

  <!-- 本桌购物车（全员实时同步） -->
  <van-popup
    show="{{cartShow}}"
    position="bottom"
    round
    z-index="{{1000}}"
    bind:close="closeCart"
    custom-style="max-height: 80vh; padding-bottom: env(safe-area-inset-bottom);"
  >
    <view class="cart-popup">
      <view class="cart-popup-header">
        <text class="cart-popup-title">本桌购物车</text>
        <text class="cart-popup-hint">实时同步 · 共 {{cartCount}} 道</text>
      </view>
      <scroll-view scroll-y class="cart-popup-list" enhanced show-scrollbar="{{false}}">
        <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
          <image class="cart-item-img" src="{{item.imageUrl || '/images/default.png'}}" mode="aspectFill"></image>
          <view class="cart-item-info">
            <view class="cart-item-row1">
              <view class="cart-item-name">{{item.name}}</view>
              <view class="cart-item-stepper" wx:if="{{item.isMine}}">
                <view class="step-btn minus" data-id="{{item.id}}" data-dish-id="{{item.dishId}}" catchtap="minusCartItem">−</view>
                <text class="step-qty">{{item.quantity}}</text>
                <view class="step-btn plus" data-dish-id="{{item.dishId}}" catchtap="plusCartItem">+</view>
              </view>
              <text wx:else class="cart-item-qty-only">×{{item.quantity}}</text>
            </view>
            <view class="cart-item-meta">
              <text class="cart-item-user">{{item.userName}} 点的</text>
            </view>
            <view
              wx:if="{{item.isMine}}"
              class="cart-item-note {{item.note ? 'has-note' : ''}}"
              data-id="{{item.id}}"
              data-note="{{item.note}}"
              catchtap="openNoteEdit"
            >
              <van-icon name="edit" size="22rpx" color="{{item.note ? '#C87E40' : '#bbb'}}" />
              <text>{{item.note || '添加备注'}}</text>
            </view>
            <view wx:elif="{{item.note}}" class="cart-item-note has-note readonly">
              <text>📝 {{item.note}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </van-popup>

  <!-- 备注编辑 -->
  <van-dialog
    use-slot
    custom-class="km-dialog"
    theme="round-button"
    confirm-button-color="#C87E40"
    title="菜品备注"
    show="{{noteEditShow}}"
    show-cancel-button
    confirm-button-text="保存"
    bind:close="closeNoteEdit"
    bind:confirm="confirmNoteEdit"
  >
    <view class="note-dialog-body">
      <textarea
        class="note-dialog-input"
        placeholder="口味、忌口、特殊要求"
        maxlength="50"
        value="{{noteEditValue}}"
        bindinput="onNoteInput"
        auto-height
      />
    </view>
  </van-dialog>
</view>
<van-dialog id="van-dialog" custom-class="km-dialog" />
<van-toast id="van-toast" />
