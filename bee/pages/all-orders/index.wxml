<view class="page">

  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading-ring"></view>
    <text>加载中...</text>
  </view>

  <view wx:elif="{{!currentFamilyId}}" class="no-family-page">
    <view class="no-family-deco"></view>
    <view class="no-family-card">
      <text class="no-family-emoji">🏠</text>
      <view class="no-family-title">还没有家庭</view>
      <view class="no-family-desc">加入或创建一个家庭，才能查看订单；也可以输入聚会码参加临时聚会</view>
      <view class="btn-primary" bindtap="goFamily">去我的家庭</view>
      <view class="btn-secondary mt32" bindtap="goParty">参加聚会</view>
    </view>
  </view>

  <view wx:else class="orders-page">

    <van-sticky z-index="{{99}}">
      <view class="top-bar" bindtap="showFamilyPicker">
        <view class="top-bar-left">
          <view class="cook-badge {{inPartyMode ? 'party' : ''}}">
            <van-icon
              name="{{inPartyMode ? 'gift-o' : 'orders-o'}}"
              size="36rpx"
              color="{{inPartyMode ? '#e64340' : '#D4A574'}}"
            />
          </view>
          <view class="top-bar-info">
            <view class="top-bar-family">{{inPartyMode ? partyName : currentFamilyName}}</view>
            <view class="top-bar-cook" wx:if="{{inPartyMode}}">
              {{isPartyGuest ? '聚会来宾 · 共享点餐' : currentFamilyName + ' · 聚会模式'}}
            </view>
            <view class="top-bar-cook" wx:elif="{{menuSubtitle}}">{{menuSubtitle}}</view>
          </view>
        </view>
        <view class="top-bar-right" wx:if="{{canSwitchFamily}}">
          <text class="top-bar-switch">切换家庭</text>
          <van-icon name="arrow-down" size="24rpx" color="#C4A57B" />
        </view>
        <view class="top-bar-right party-code" wx:elif="{{inPartyMode}}" catchtap="goParty">
          <text class="top-bar-switch">聚会码 {{joinCode}}</text>
        </view>
      </view>
    </van-sticky>

    <view wx:if="{{inPartyMode}}" class="party-banner" bindtap="goParty">
      <text class="party-banner-emoji">🎉</text>
      <view class="party-banner-text">
        <text class="party-banner-title">聚会进行中</text>
        <text class="party-banner-sub">来宾可同桌加菜 · 点击查看聚会详情</text>
      </view>
      <van-icon name="arrow" size="28rpx" color="#C87E40" />
    </view>

    <view wx:if="{{summary.total_dishes > 0}}" class="summary-card">
      <view class="summary-header">
        <view class="summary-dot"></view>
        <text class="summary-title">本桌汇总（共 {{summary.total_dishes}} 道）</text>
        <text class="live-tag {{wsConnected ? 'on' : 'off'}}">{{wsConnected ? '实时' : '连接中'}}</text>
      </view>
      <view class="summary-dishes">
        <view class="summary-dish" wx:for="{{summary.dish_totals}}" wx:key="dish_name">
          <image class="summary-dish-img" src="{{item.imageUrl || '/images/default.png'}}" mode="aspectFill"></image>
          <view class="summary-dish-info">
            <text class="summary-dish-name">{{item.display_name || item.dish_name}}</text>
            <text class="summary-dish-qty">×{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{summary.by_cook.length > 0}}" class="section">
      <view class="section-header">
        <view class="section-dot"></view>
        <text>谁来做哪道菜</text>
      </view>
      <view class="user-group" wx:for="{{summary.by_cook}}" wx:key="cook_user_id">
        <view class="user-group-header cook-header">
          <view class="user-avatar cook">{{item.cook_name[0]}}</view>
          <text class="user-name">{{item.cook_name}} 做</text>
        </view>
        <view class="user-items">
          <view class="user-item" wx:for="{{item.items}}" wx:for-item="dish" wx:key="id">
            <image class="user-item-img" src="{{dish.imageUrl || '/images/default.png'}}" mode="aspectFill"></image>
            <view class="user-item-main">
              <view class="user-item-top">
                <text class="user-item-name">{{dish.dish_name}}</text>
                <text class="user-item-qty">×{{dish.quantity}}</text>
              </view>
              <text wx:if="{{dish.note}}" class="user-item-note">📝 {{dish.note}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{summary.total_dishes > 0}}" class="submit-bar">
      <view class="submit-hint">
        {{canCompleteMeal ? '大家可随时加菜，出完餐后由你确认结束本轮' : '大家可随时加菜，出完餐后由管理员或聚会发起者确认结束本轮'}}
      </view>
      <view
        wx:if="{{canCompleteMeal}}"
        class="submit-btn {{submitting ? 'disabled' : ''}}"
        bindtap="confirmMealComplete"
      >
        {{submitting ? '确认中...' : '确认出餐'}}
      </view>
    </view>

    <view wx:if="{{!loading && summary.total_dishes === 0}}" class="empty-box">
      <text class="empty-emoji">📋</text>
      <view class="empty-title">本桌还没有点菜</view>
      <view class="empty-desc">去点餐页选菜，加入本桌后这里会实时汇总</view>
      <view class="btn-primary mt32" bindtap="goOrder">去点餐</view>
    </view>

  </view>
</view>
<van-dialog id="van-dialog" custom-class="km-dialog" />
<van-toast id="van-toast" />
