@import "../../styles/join-flow.wxss";

.loading-ring {
  width: 72rpx;
  height: 72rpx;
  border: 6rpx solid #F0E4D0;
  border-top-color: #D4A574;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.header-bg {
  height: 280rpx;
  background: linear-gradient(135deg, #fff5ed 0%, #ffd4c4 50%, #e64340 120%);
}

.join-card {
  margin: -120rpx 32rpx 0;
  padding: 48rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(230, 67, 64, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.join-icon {
  font-size: 72rpx;
  line-height: 1;
}

.title {
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #888;
  text-align: center;
  line-height: 1.6;
}

.input-wrap {
  width: 100%;
  margin-top: 48rpx;
}

.code-input {
  width: 100%;
  height: 100rpx;
  padding: 0 24rpx;
  background: #f7f7f7;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  font-size: 44rpx;
  font-weight: 600;
  letter-spacing: 10rpx;
  text-align: center;
  color: #e64340;
  box-sizing: border-box;
}

.code-input:focus {
  border-color: rgba(230, 67, 64, 0.3);
  background: #fff;
}

.submit-btn {
  margin-top: 32rpx;
}

.tips-card {
  margin: 32rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tips-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.tips-item {
  font-size: 26rpx;
  color: #888;
  line-height: 2;
}
