.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.header-bg {
  height: 240rpx;
  background: linear-gradient(135deg, #fff5ed 0%, #ffd4c4 50%, #e64340 120%);
}

.header-content {
  margin: -120rpx 32rpx 0;
  padding: 36rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(230, 67, 64, 0.1);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.page-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin: 24rpx 32rpx 0;
}

.action-card {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.action-card:active {
  opacity: 0.85;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-icon.create {
  background: rgba(230, 67, 64, 0.1);
}

.action-icon.join {
  background: rgba(255, 152, 0, 0.12);
}

.action-text {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.action-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.action-desc {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #999;
}

.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #e64340;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

.empty-card {
  margin: 32rpx;
  padding: 64rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.empty-icon {
  font-size: 80rpx;
  line-height: 1;
}

.empty-title {
  margin-top: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-desc {
  margin: 12rpx 0 40rpx;
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

.section {
  margin: 32rpx 32rpx 0;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.title-dot {
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #e64340, #ff8a80);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.family-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.family-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.family-card:active {
  background: #fafafa;
}

.family-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: rgba(230, 67, 64, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.family-body {
  flex: 1;
  min-width: 0;
  margin: 0 20rpx;
}

.family-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.family-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.role-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.role-admin {
  background: rgba(230, 67, 64, 0.12);
  color: #e64340;
}

.role-chef {
  background: rgba(255, 152, 0, 0.12);
  color: #f57c00;
}

.role-diner {
  background: rgba(76, 175, 80, 0.12);
  color: #4caf50;
}

.member-count {
  font-size: 24rpx;
  color: #999;
}

.dialog-body {
  padding: 16rpx 32rpx 32rpx;
}

.dialog-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
