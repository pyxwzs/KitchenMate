<view class="page">
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading-ring"></view>
    <text>加入中...</text>
  </view>

  <block wx:else>
  <view class="header-bg"></view>

  <view class="join-card">
    <view class="join-icon">🔑</view>
    <view class="title">加入家庭</view>
    <view class="subtitle">请向家庭管理员获取邀请码，输入后即可加入</view>

    <view class="input-wrap">
      <input
        class="code-input"
        placeholder="请输入邀请码"
        maxlength="8"
        value="{{inviteCode}}"
        bindinput="onInput"
      />
    </view>

    <van-button type="danger" round block custom-class="submit-btn" bind:click="submitJoin">
      确认加入
    </van-button>
  </view>

  <view class="tips-card">
    <view class="tips-title">
      <van-icon name="info-o" size="32rpx" color="#e64340" />
      <text>小提示</text>
    </view>
    <view class="tips-item">· 邀请码通常为 6 位字母或数字</view>
    <view class="tips-item">· 加入后可查看家庭菜单并参与点餐</view>
    <view class="tips-item">· 如需创建家庭，请返回上一页选择「创建家庭」</view>
  </view>
  </block>
</view>
