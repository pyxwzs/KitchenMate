.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.header-bg {
  height: 200rpx;
  background: linear-gradient(135deg, #fff5ed 0%, #ffd4c4 60%, #e64340 120%);
}

.hero-card {
  margin: -80rpx 32rpx 0;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(230, 67, 64, 0.1);
}

.hero-top {
  display: flex;
  align-items: center;
}

.family-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: rgba(230, 67, 64, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-info {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.family-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.member-total {
  font-size: 24rpx;
  color: #999;
}

.cook-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.invite-card {
  margin-top: 32rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #fff8f6 0%, #fff 100%);
  border: 2rpx solid rgba(230, 67, 64, 0.12);
  border-radius: 20rpx;
}

.invite-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.invite-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.invite-code-wrap {
  margin: 24rpx 0 12rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  text-align: center;
}

.invite-code {
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 12rpx;
  color: #e64340;
  font-family: 'Courier New', monospace;
}

.invite-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.invite-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.invite-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.invite-btn.primary {
  background: #e64340;
  color: #fff;
}

.invite-btn.secondary {
  background: #fff;
  color: #e64340;
  border: 2rpx solid rgba(230, 67, 64, 0.3);
}

.invite-btn.qr {
  background: #fff8f0;
  color: #C87E40;
  border: 2rpx solid rgba(200, 126, 64, 0.35);
}

.invite-btn:active {
  opacity: 0.85;
}

.qr-popup { display: flex; flex-direction: column; align-items: center; }
.qr-title { font-size: 32rpx; font-weight: 700; color: #3D2817; }
.qr-name { margin-top: 8rpx; font-size: 26rpx; color: #A08B6F; }
.qr-box {
  width: 360rpx;
  height: 360rpx;
  margin: 32rpx 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  border-radius: 16rpx;
}
.qr-image { width: 320rpx; height: 320rpx; }
.qr-loading { display: flex; flex-direction: column; align-items: center; gap: 16rpx; color: #A08B6F; font-size: 24rpx; }
.qr-loading .loading-ring {
  width: 64rpx;
  height: 64rpx;
  border: 5rpx solid #F0E4D0;
  border-top-color: #D4A574;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.qr-code-text { font-size: 28rpx; color: #666; letter-spacing: 4rpx; }
.qr-tip { margin-top: 12rpx; font-size: 22rpx; color: #999; text-align: center; line-height: 1.6; }
.qr-tip.official { color: #C87E40; }
.qr-actions { display: flex; gap: 16rpx; margin-top: 32rpx; width: 100%; }
.qr-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 36rpx;
  font-size: 28rpx;
  background: #f5f5f5;
  color: #666;
}
.qr-btn.primary { background: linear-gradient(135deg, #E8A060, #C87E40); color: #fff; }

.party-section {
  margin: 24rpx 32rpx 0;
}

.party-card {
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(156, 39, 176, 0.12);
}

.party-card.active {
  border-color: rgba(232, 160, 96, 0.35);
  background: linear-gradient(135deg, #FFF8E1, #fff);
}

.party-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.party-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.party-card-name {
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #3D2817;
}

.party-card-code, .party-card-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.party-card-link {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #C87E40;
  font-weight: 600;
}

.quick-row {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 32rpx 0;
}

.quick-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 88rpx;
  background: #fff;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #e64340;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.quick-btn.primary {
  background: #e64340;
  color: #fff;
}

.quick-btn:active {
  opacity: 0.85;
}

.section {
  margin: 32rpx 32rpx 0;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.title-dot {
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #e64340, #ff8a80);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-count {
  margin-left: 8rpx;
  font-size: 26rpx;
  font-weight: 400;
  color: #999;
}

.role-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.role-admin {
  background: rgba(230, 67, 64, 0.12);
  color: #e64340;
}

.role-chef {
  background: rgba(255, 152, 0, 0.12);
  color: #f57c00;
}

.role-diner {
  background: rgba(76, 175, 80, 0.12);
  color: #4caf50;
}

.member-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.member-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-item.tappable:active {
  background: #fafafa;
}

.member-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.member-info {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.member-name {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.me-tag {
  padding: 2rpx 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 400;
  color: #999;
}

.edit-hint {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #bbb;
  flex-shrink: 0;
}

.admin-tip {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.leave-section {
  margin: 48rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

.leave-tip {
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
  background: #fff8e1;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #a08b6f;
  line-height: 1.6;
  text-align: center;
}

.leave-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  border: 2rpx solid #e64340;
  border-radius: 44rpx;
  font-size: 30rpx;
  color: #e64340;
  font-weight: 500;
}

.leave-btn.disabled {
  opacity: 0.45;
  border-color: #ccc;
  color: #999;
}

.leave-btn:active:not(.disabled) {
  opacity: 0.85;
}

.delete-btn {
  margin-top: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #e64340;
  border-radius: 44rpx;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.delete-btn:active {
  opacity: 0.85;
}
