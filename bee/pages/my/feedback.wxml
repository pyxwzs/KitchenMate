<view class="feedback-container">
  <view class="header-wave"></view>

  <view class="feedback-header">
    <view class="header-icon">💭</view>
    <view class="header-title">听听您的心声</view>
    <view class="header-subtitle">您的每一条建议都是我们前进的动力</view>
  </view>

  <view class="feedback-card">
    <view class="input-section">
      <view class="input-label">
        <view class="label-icon">👤</view>
        <view class="label-text">姓名</view>
      </view>
      <van-field
        placeholder="请输入您的姓名"
        model:value="{{ name }}"
        clearable
        border="{{ false }}"
        custom-class="custom-field"
      />
    </view>

    <view class="divider"></view>

    <view class="input-section">
      <view class="input-label">
        <view class="label-icon">📱</view>
        <view class="label-text">联系电话</view>
      </view>
      <van-field
        placeholder="选填，方便我们联系您"
        type="number"
        model:value="{{ mobile }}"
        clearable
        border="{{ false }}"
        custom-class="custom-field"
      />
    </view>

    <view class="divider"></view>

    <view class="input-section content-section">
      <view class="input-label">
        <view class="label-icon">✍️</view>
        <view class="label-text">反馈内容</view>
      </view>
      <van-field
        model:value="{{ content }}"
        placeholder="请描述您遇到的问题或建议"
        type="textarea"
        autosize="{{ autosize }}"
        border="{{ false }}"
        custom-class="custom-textarea"
      />
    </view>

    <view class="upload-section">
      <view class="input-label">
        <view class="label-icon">📷</view>
        <view class="label-text">图片</view>
        <view class="label-tip">(选填)</view>
      </view>
      <view class="uploader-wrapper">
        <van-uploader
          accept="media"
          multiple
          max-count="6"
          image-fit="aspectFill"
          file-list="{{ picsList }}"
          bind:after-read="afterPicRead"
          bind:delete="afterPicDel"
        />
      </view>
    </view>
  </view>

  <view class="tips-card">
    <view class="tips-icon">💡</view>
    <view class="tips-content">
      <view class="tips-title">温馨提示</view>
      <view class="tips-text">反馈功能完善后将同步到服务器，目前仅作本地记录</view>
    </view>
  </view>

  <view class="submit-wrapper">
    <view class="submit-btn" bind:tap="bindSave">
      <view class="btn-text">提交反馈</view>
      <view class="btn-icon">→</view>
    </view>
  </view>
</view>
<van-dialog id="van-dialog" custom-class="km-dialog" />
<van-toast id="van-toast" />
