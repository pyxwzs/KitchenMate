<view class="page-container">
  <view class="header-bg"></view>

  <view class="profile-card" wx:if="{{apiUserInfoMap}}">
    <view class="avatar-wrap">
      <image
        src="{{ displayAvatar || '/images/default.png' }}"
        mode="aspectFill"
        class="avatar-img"
        binderror="onAvatarError"
      ></image>
      <button class="avatar-btn-overlay" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar"></button>
    </view>
    <view class="profile-info">
      <view class="nickname" bindtap="editNick">{{ nick || '微信用户' }}</view>
      <view class="real-name" wx:if="{{apiUserInfoMap.base.realName}}">
        <text class="label">姓名</text>
        <text class="value">{{ apiUserInfoMap.base.realName }}</text>
      </view>
    </view>
  </view>

  <view class="profile-card" wx:else bindtap="handleLogin">
    <image src="/images/default.png" mode="aspectFill" class="avatar-img"></image>
    <view class="profile-info">
      <view class="nickname">未登录</view>
      <view class="login-hint">点击登录</view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-title">
        <view class="title-dot"></view>
        <text>功能</text>
      </view>
      <view class="menu-list">
        <navigator url="/pages/my/dishes" hover-class="none">
          <view class="menu-list-item">
            <view class="item-left">
              <van-icon name="fire-o" size="40rpx" color="#ff9800" />
              <text class="list-text">我会做的菜</text>
            </view>
            <van-icon name="arrow" size="32rpx" color="#999" />
          </view>
        </navigator>
        <navigator url="/pages/family/index" hover-class="none">
          <view class="menu-list-item">
            <view class="item-left">
              <van-icon name="friends-o" size="40rpx" color="#e64340" />
              <text class="list-text">我的家庭</text>
            </view>
            <van-icon name="arrow" size="32rpx" color="#999" />
          </view>
        </navigator>
        <navigator url="/pages/all-orders/index" open-type="switchTab" hover-class="none">
          <view class="menu-list-item">
            <view class="item-left">
              <van-icon name="orders-o" size="40rpx" color="#4caf50" />
              <text class="list-text">我的订单</text>
            </view>
            <van-icon name="arrow" size="32rpx" color="#999" />
          </view>
        </navigator>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-title">
        <view class="title-dot"></view>
        <text>设置</text>
      </view>
      <view class="menu-list">
        <navigator url="/pages/about/index" hover-class="none">
          <view class="menu-list-item">
            <view class="item-left">
              <van-icon name="info-o" size="40rpx" color="#888" />
              <text class="list-text">关于我们</text>
            </view>
            <van-icon name="arrow" size="32rpx" color="#999" />
          </view>
        </navigator>
        <navigator url="/pages/my/feedback" hover-class="none">
          <view class="menu-list-item">
            <view class="item-left">
              <van-icon name="chat-o" size="40rpx" color="#888" />
              <text class="list-text">意见反馈</text>
            </view>
            <van-icon name="arrow" size="32rpx" color="#999" />
          </view>
        </navigator>
        <view class="menu-list-item" bindtap="clearStorage">
          <view class="item-left">
            <van-icon name="delete-o" size="40rpx" color="#888" />
            <text class="list-text">清除缓存</text>
          </view>
          <van-icon name="arrow" size="32rpx" color="#999" />
        </view>
      </view>
    </view>
  </view>

  <view class="version-text">v{{version}}</view>
</view>

<van-dialog
  use-slot
  custom-class="km-dialog"
  theme="round-button"
  confirm-button-color="#C87E40"
  title="修改昵称"
  show="{{ nickShow }}"
  show-cancel-button
  bind:confirm="_editNick"
>
  <van-field
    model:value="{{ nick }}"
    type="nickname"
    placeholder="请输入昵称"
    size="large"
    clearable
  />
</van-dialog>
<van-dialog id="van-dialog" custom-class="km-dialog" />
<van-toast id="van-toast" />
