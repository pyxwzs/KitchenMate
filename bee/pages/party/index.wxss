@import "../../styles/join-flow.wxss";

.page {
  min-height: 100vh;
  background: #F7F2EC;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 50vh;
  gap: 20rpx;
  color: #A08B6F;
}

.loading-ring {
  width: 64rpx;
  height: 64rpx;
  border: 5rpx solid #F0E4D0;
  border-top-color: #D4A574;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.hero-card {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.hero-badge { font-size: 64rpx; line-height: 1; }
.hero-title { margin-top: 16rpx; font-size: 40rpx; font-weight: 700; color: #3D2817; }
.hero-sub { margin-top: 8rpx; font-size: 26rpx; color: #A08B6F; }

.status-tag {
  display: inline-block;
  margin-top: 16rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(76, 175, 80, 0.15);
  color: #388E3C;
}

.code-card, .info-card, .intro-card, .hub-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.06);
}

.code-label { font-size: 24rpx; color: #888; text-align: center; }
.code-value {
  margin: 16rpx 0 24rpx;
  text-align: center;
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #C87E40;
}

.code-actions { display: flex; gap: 12rpx; }
.code-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 36rpx;
  font-size: 24rpx;
  background: #F5EDE3;
  color: #8B6F47;
}
.code-btn.primary {
  background: linear-gradient(135deg, #E8A060, #C87E40);
  color: #fff;
}
.code-btn.qr {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: 2rpx solid #E8A060;
  background: #fff;
  color: #C87E40;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.info-label { font-size: 28rpx; color: #666; }
.info-value { font-size: 28rpx; font-weight: 600; color: #3D2817; }

.guest-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.guest-chip {
  padding: 8rpx 20rpx;
  background: #FAF6F0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #8B6F47;
}
.guest-empty { font-size: 24rpx; color: #999; }

.action-row { display: flex; gap: 16rpx; margin-top: 8rpx; }
.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #F5EDE3;
  color: #8B6F47;
}
.action-btn.primary {
  background: linear-gradient(135deg, #E8A060, #C87E40);
  color: #fff;
}

.close-btn {
  margin-top: 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #e64340;
  padding: 20rpx;
}

.intro-card { text-align: center; padding: 48rpx 32rpx; }
.intro-emoji { font-size: 72rpx; }
.intro-title { margin-top: 16rpx; font-size: 36rpx; font-weight: 700; color: #3D2817; }
.intro-desc { margin-top: 12rpx; font-size: 26rpx; color: #888; line-height: 1.6; }

.hub-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.hub-card.join { display: block; }
.hub-text { flex: 1; }
.hub-title { display: block; font-size: 30rpx; font-weight: 600; color: #333; }
.hub-desc { display: block; margin-top: 6rpx; font-size: 24rpx; color: #999; }

.join-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.join-inner { width: 100%; }

.scan-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(232, 160, 96, 0.4);
}
.scan-text { font-size: 30rpx; font-weight: 600; color: #C87E40; }

.join-divider {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 16rpx;
  color: #bbb;
  font-size: 24rpx;
}
.join-divider::before,
.join-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #eee;
}

.join-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  font-size: 32rpx;
  letter-spacing: 4rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}
.join-btn {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #E8A060, #C87E40);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}
.join-btn.disabled { opacity: 0.6; }

/* ── 二维码弹窗 ── */
.qr-popup { display: flex; flex-direction: column; align-items: center; }
.qr-title { font-size: 32rpx; font-weight: 700; color: #3D2817; }
.qr-name { margin-top: 8rpx; font-size: 26rpx; color: #888; }
.qr-box {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  margin: 32rpx 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
  border-radius: 16rpx;
  overflow: hidden;
}
.qr-image { width: 380rpx; height: 380rpx; }
.qr-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: #aaa;
  font-size: 24rpx;
}
.qr-code-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}
.qr-code-big {
  font-size: 72rpx;
  font-weight: 800;
  letter-spacing: 12rpx;
  color: #C87E40;
  margin-bottom: 16rpx;
}
.qr-code-hint { font-size: 22rpx; color: #999; text-align: center; line-height: 1.6; }
.qr-code-text { font-size: 28rpx; color: #C87E40; font-weight: 600; letter-spacing: 4rpx; }
.qr-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
}
.qr-tip.official { color: #388E3C; font-weight: 500; }
.qr-actions { display: flex; gap: 20rpx; margin-top: 32rpx; width: 100%; }
.qr-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #F5EDE3;
  color: #8B6F47;
}
.qr-btn.primary {
  background: linear-gradient(135deg, #E8A060, #C87E40);
  color: #fff;
}

.dialog-body { padding: 24rpx 32rpx 8rpx; }
.dialog-field {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.field-label { font-size: 28rpx; color: #666; }
.field-value { font-size: 28rpx; color: #333; }
.dialog-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
