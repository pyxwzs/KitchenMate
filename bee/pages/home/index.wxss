.home-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5ed 0%, #ffffff 100%);
  padding: 48rpx 32rpx 80rpx;
  box-sizing: border-box;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.logo {
  width: 280rpx;
}

.app-name {
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.user-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(230, 67, 64, 0.08);
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.user-info {
  margin-left: 24rpx;
}

.user-nick {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.user-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}

.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 32rpx;
}

.current-family-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(230, 67, 64, 0.12);
}

.current-family-card.tappable:active {
  opacity: 0.85;
}

.current-family-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.current-family-title {
  font-size: 24rpx;
  color: #999;
}

.current-family-name {
  margin-top: 4rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.current-family-switch {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #C4A57B;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.action-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.action-card.primary {
  border: 2rpx solid rgba(230, 67, 64, 0.15);
}

.action-card.party {
  border: 2rpx solid rgba(156, 39, 176, 0.15);
}

.party-active-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  border: 2rpx solid rgba(232, 160, 96, 0.35);
}

.party-active-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.party-active-emoji { font-size: 44rpx; flex-shrink: 0; }
.party-active-title { font-size: 30rpx; font-weight: 700; color: #3D2817; }
.party-active-desc { margin-top: 6rpx; font-size: 24rpx; color: #A08B6F; }

.action-title {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.action-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}
