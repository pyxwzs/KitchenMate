<view class="page" wx:if="{{order}}">

  <view class="header-card">
    <view class="header-row">
      <text class="order-time">{{order.timeText}}</text>
      <view class="order-status {{statusClass[order.status]}}">{{order.status_label}}</view>
    </view>
    <view class="header-summary">共 {{order.totalDishes}} 道菜 · {{order.kindCount}} 个品种</view>
    <view wx:if="{{order.locked_by_name}}" class="header-sub">{{order.locked_by_name}} 提交</view>
    <view wx:if="{{order.note}}" class="order-note">备注：{{order.note}}</view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-dot"></view>
      <text>菜品汇总</text>
    </view>
    <view class="summary-card">
      <view class="summary-dish" wx:for="{{order.dish_totals}}" wx:key="dish_name">
        <image class="summary-dish-img" src="{{item.imageUrl || '/images/default.png'}}" mode="aspectFill"></image>
        <view class="summary-dish-info">
          <text class="summary-dish-name">{{item.dish_name}}</text>
          <text class="summary-dish-qty">×{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{order.by_cook.length > 0}}" class="section">
    <view class="section-header">
      <view class="section-dot"></view>
      <text>谁来做哪道菜</text>
    </view>
    <view class="user-group" wx:for="{{order.by_cook}}" wx:key="cook_user_id">
      <view class="user-group-header">
        <view class="user-avatar">{{item.cook_name[0]}}</view>
        <text class="user-name">{{item.cook_name}} 做</text>
        <text class="user-total">{{item.total}} 道</text>
      </view>
      <view class="user-items">
        <view class="user-item" wx:for="{{item.items}}" wx:for-item="dish" wx:key="id">
          <image class="user-item-img" src="{{dish.imageUrl || '/images/default.png'}}" mode="aspectFill"></image>
          <view class="user-item-main">
            <view class="user-item-top">
              <text class="user-item-name">{{dish.dish_name}}</text>
              <text class="user-item-qty">×{{dish.quantity}}</text>
            </view>
            <text wx:if="{{dish.note}}" class="user-item-note">📝 {{dish.note}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

</view>
