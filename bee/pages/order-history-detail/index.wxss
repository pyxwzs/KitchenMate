.page {
  min-height: 100vh;
  background: #F7F2EC;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.06);
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-time {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2817;
}

.header-summary {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #C87E40;
  font-weight: 600;
}

.header-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #A08B6F;
}

.order-note {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: #FAF6F0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #888;
}

.order-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-done { background: rgba(76, 175, 80, 0.12); color: #388E3C; }
.status-cancelled { background: #F5F5F5; color: #999; }
.status-pending { background: rgba(255, 152, 0, 0.12); color: #F57C00; }

.section { margin-bottom: 24rpx; }

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.section-dot {
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #E8A060, #C87E40);
  border-radius: 4rpx;
}

.section-header text {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D2817;
}

.summary-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.06);
}

.summary-dish {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F8F2EB;
}

.summary-dish:last-child { border-bottom: none; }

.summary-dish-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.summary-dish-info {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-dish-name { font-size: 28rpx; color: #3D2817; }
.summary-dish-qty { font-size: 28rpx; font-weight: 700; color: #C87E40; }

.user-group {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.06);
}

.user-group-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD4A3, #E8A060);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2817;
}

.user-total {
  font-size: 24rpx;
  color: #C87E40;
  font-weight: 600;
}

.user-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F8F2EB;
}

.user-item:last-child { border-bottom: none; }

.user-item-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F5EDE3;
}

.user-item-main { flex: 1; min-width: 0; }
.user-item-top { display: flex; align-items: center; justify-content: space-between; }
.user-item-name { flex: 1; font-size: 26rpx; color: #555; }
.user-item-qty { font-size: 26rpx; font-weight: 600; color: #C87E40; flex-shrink: 0; margin-left: 8rpx; }
.user-item-note { display: block; margin-top: 6rpx; font-size: 22rpx; color: #A08B6F; line-height: 1.4; }
