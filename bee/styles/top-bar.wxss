/* 点餐 / 订单页共用顶栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #F0E8DA;
  box-shadow: 0 4rpx 16rpx rgba(180, 130, 80, 0.08);
}

.top-bar-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.cook-badge {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cook-badge.party {
  background: linear-gradient(135deg, #FFEBEE, #FFCDD2);
}

.top-bar-info {
  flex: 1;
  min-width: 0;
}

.top-bar-family {
  font-size: 38rpx;
  font-weight: 700;
  color: #2D1F0F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-bar-cook {
  margin-top: 6rpx;
  font-size: 28rpx;
  color: #C4A57B;
}

.top-bar-right {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.top-bar-switch {
  font-size: 26rpx;
  color: #C4A57B;
}

.top-bar-right.party-code .top-bar-switch {
  color: #e64340;
  font-weight: 600;
}

.party-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 16rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  border-radius: 16rpx;
  border: 1rpx solid rgba(232, 160, 96, 0.3);
}

.party-banner-emoji {
  font-size: 36rpx;
  flex-shrink: 0;
}

.party-banner-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.party-banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2817;
}

.party-banner-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #A08B6F;
}
