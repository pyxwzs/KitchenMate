.join-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(8px);
}

.join-overlay-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  animation: joinFadeIn 0.35s ease;
}

.join-overlay-inner.success {
  animation: joinScaleIn 0.45s ease;
}

.join-check {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #389e0d);
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 32rpx rgba(82, 196, 26, 0.35);
  margin-bottom: 32rpx;
}

.join-overlay-emoji {
  font-size: 88rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.join-overlay-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
}

.join-overlay-sub {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #888;
  text-align: center;
  line-height: 1.6;
}

.join-overlay-error {
  margin-top: 24rpx;
  padding: 16rpx 28rpx;
  background: #fff2f0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #e64340;
  text-align: center;
  max-width: 520rpx;
}

.join-overlay-btn {
  margin-top: 40rpx;
  padding: 0 48rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
}

.scan-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #fff5ed, #ffd4c4);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(230, 67, 64, 0.25);
}

.scan-row:active {
  opacity: 0.85;
}

.scan-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #e64340;
}

.join-divider {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
  color: #bbb;
  font-size: 24rpx;
  width: 100%;
}

.join-divider::before,
.join-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #eee;
}

@keyframes joinFadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes joinScaleIn {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}
